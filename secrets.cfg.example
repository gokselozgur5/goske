; Copy this file to secrets.cfg and fill in.
; secrets.cfg is gitignored. Never commit real keys.

[anthropic]

; Local dev: paste your Anthropic Console key here.
api_key = "sk-ant-..."

; Demo / web build: point at the Cloudflare Worker proxy URL instead, and
; leave api_key empty. The Worker holds the real key as a server secret.
; See worker/README.md for setup.
;
; api_url = "https://goske-proxy.<account>.workers.dev"
; api_key = ""
